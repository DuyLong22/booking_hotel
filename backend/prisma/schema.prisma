// Cấu hình ban đầu
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

enum Role {
  CUSTOMER
  HOTEL_OWNER
  ADMIN
  STAFF
}

enum BookingStatus {
  PENDING
  PAYMENT_PROCESSING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum HotelStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  fullName      String
  phoneNumber   String?
  avatarUrl     String?
  role          Role      @default(CUSTOMER)
  isVerified    Boolean   @default(false)
  isApproved    Boolean   @default(true)
  otpCode       String?
  otpExpiresAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  refreshTokens RefreshToken[]
  sessions      Session[]
  hotels        Hotel[]        @relation("HotelOwner")
  bookings      Booking[]
  reviews       Review[]
  favorites     Favorite[]
  recentlyViewed RecentlyViewed[]
  couponUsages  CouponUsage[]
  notifications Notification[]
  sentMessages  Message[]      @relation("Sender")
  conversationsAsCustomer Conversation[] @relation("CustomerConversations")
  conversationsAsOwner    Conversation[] @relation("OwnerConversations")
  auditLogs     AuditLog[]
  loyaltyPoints Int @default(0)
  loyaltyTransactions LoyaltyTransaction[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// Địa giới hành chính Việt Nam
model Province {
  id        String     @id
  name      String     @unique
  code      String     @unique
  districts District[]
  hotels    Hotel[]
}

model District {
  id         String   @id
  provinceId String
  name       String
  code       String
  province   Province @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  wards      Ward[]
  hotels     Hotel[]
}

model Ward {
  id         String   @id
  districtId String
  name       String
  code       String
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)
  hotels     Hotel[]
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique // Resort, Homestay, Hotel, Villa...
  slug        String   @unique
  imageUrl    String?
  description String?
  hotels      Hotel[]
}

model Hotel {
  id            String         @id @default(uuid())
  ownerId       String
  categoryId    String
  name          String
  description   String
  address       String // Số nhà, tên đường
  provinceId    String
  districtId    String
  wardId        String
  latitude      Float?
  longitude     Float?
  starRating    Int            @default(3)
  status        HotelStatus    @default(PENDING)
  rejectReason  String?
  checkInTime   String?        @default("14:00")
  checkOutTime  String?        @default("12:00")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  owner         User           @relation("HotelOwner", fields: [ownerId], references: [id])
  category      Category       @relation(fields: [categoryId], references: [id])
  province      Province       @relation(fields: [provinceId], references: [id])
  district      District       @relation(fields: [districtId], references: [id])
  ward          Ward           @relation(fields: [wardId], references: [id])
  images        HotelImage[]
  amenities     HotelAmenity[]
  roomTypes     RoomType[]
  reviews       Review[]
  favorites     Favorite[]
  recentlyViewed RecentlyViewed[]
  coupons       Coupon[]
  conversations Conversation[]
  nearbyLocations NearbyLocation[]
}

model HotelImage {
  id        String   @id @default(uuid())
  hotelId   String
  url       String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model Amenity {
  id        String         @id @default(uuid())
  name      String         @unique // Wifi, Hồ bơi, Gym, Bãi đỗ xe...
  icon      String?        // Tên icon (Lucide)
  hotels    HotelAmenity[]
}

model HotelAmenity {
  hotelId   String
  amenityId String
  hotel     Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  amenity   Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([hotelId, amenityId])
}

model RoomType {
  id            String              @id @default(uuid())
  hotelId       String
  name          String              // Deluxe Double, Suite Family...
  description   String
  basePrice     Decimal             @db.Decimal(10, 2)
  capacity      Int                 // Số lượng khách tối đa
  bedCount      Int                 @default(1)
  size          Int?                // Diện tích (m2)
  amenities         String[]            // Các tiện ích riêng của phòng
  includeBreakfast  Boolean             @default(false)
  childSurcharge    Int                 @default(0)
  cancellationPolicy String             @default("FREE_24H") // "FREE_24H", "NON_REFUNDABLE"
  paymentPolicy     String              @default("PAY_AT_HOTEL") // "PAY_AT_HOTEL", "PAY_ONLINE"
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  // Relations
  hotel         Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  images        RoomImage[]
  rooms         Room[]
  priceCalendar RoomPriceCalendar[]
  bookingItems  BookingItem[]
}

model RoomImage {
  id         String   @id @default(uuid())
  roomTypeId String
  url        String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
}

model Room {
  id          String   @id @default(uuid())
  roomTypeId  String
  roomNumber  String
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roomType    RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
}

// Bảng lịch giá động & Khóa phòng
model RoomPriceCalendar {
  id          String   @id @default(uuid())
  roomTypeId  String
  date        DateTime // Ngày cụ thể
  price       Decimal  @db.Decimal(10, 2) // Giá áp dụng cho ngày này
  isBlocked   Boolean  @default(false)    // Chặn đặt phòng ngày này
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roomType    RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, date])
}

model Booking {
  id             String        @id @default(uuid())
  userId         String
  checkInDate    DateTime
  checkOutDate   DateTime
  totalPrice     Decimal       @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)
  finalPrice     Decimal       @db.Decimal(10, 2)
  status            BookingStatus @default(PENDING)
  insuranceSelected Boolean       @default(false)
  guestName         String
  guestEmail        String
  guestPhone        String
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  pointsUsed     Int           @default(0)
  pointsDiscount Decimal       @default(0) @db.Decimal(10, 2)

  // Relations
  user           User          @relation(fields: [userId], references: [id])
  bookingItems   BookingItem[]
  payment        Payment?
  couponUsages   CouponUsage[]
}

model BookingItem {
  id         String   @id @default(uuid())
  bookingId  String
  roomTypeId String
  quantity   Int      @default(1)
  price      Decimal  @db.Decimal(10, 2) // Giá tại thời điểm đặt (tính tổng từ calendar)
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  roomType   RoomType @relation(fields: [roomTypeId], references: [id])
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique
  amount        Decimal       @db.Decimal(10, 2)
  method        String        // VNPAY, MOMO, STRIPE, CASH
  status        PaymentStatus @default(PENDING)
  transactionId String?       @unique
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Review {
  id                String   @id @default(uuid())
  userId            String
  hotelId           String
  ratingCleanliness Int      // 1 đến 5 hoặc 1 đến 10
  ratingLocation    Int
  ratingService     Int
  ratingFacilities  Int
  ratingValue       Int
  ratingOverall     Float    // Trung bình cộng của 5 tiêu chí
  comment           String
  images            String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel             Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model Favorite {
  userId    String
  hotelId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel     Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@id([userId, hotelId])
}

model RecentlyViewed {
  id        String   @id @default(uuid())
  userId    String
  hotelId   String
  viewedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model Coupon {
  id                String        @id @default(uuid())
  hotelId           String?       // Null nếu là coupon toàn sàn
  code              String        @unique
  description       String
  discountType      String        // PERCENTAGE hoặc FIXED
  discountValue     Decimal       @db.Decimal(10, 2)
  minOrderValue     Decimal       @default(0) @db.Decimal(10, 2)
  maxDiscountAmount Decimal?      @db.Decimal(10, 2)
  startDate         DateTime
  endDate           DateTime
  usageLimit        Int
  usedCount         Int           @default(0)
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())

  hotel             Hotel?        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  usages            CouponUsage[]
}

model CouponUsage {
  id        String   @id @default(uuid())
  couponId  String
  userId    String
  bookingId String
  usedAt    DateTime @default(now())

  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  type      String   // BOOKING, PAYMENT, SYSTEM, CHAT
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Hệ thống Chat Realtime
model Conversation {
  id           String    @id @default(uuid())
  customerId   String
  hotelOwnerId String
  hotelId      String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  customer     User      @relation("CustomerConversations", fields: [customerId], references: [id])
  hotelOwner   User      @relation("OwnerConversations", fields: [hotelOwnerId], references: [id])
  hotel        Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([customerId, hotelOwnerId, hotelId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("Sender", fields: [senderId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  action      String   // ví dụ: "UPDATE_PRICE", "APPROVE_HOTEL", "DELETE_REVIEW"
  entityName  String   // ví dụ: "RoomPriceCalendar", "Hotel", "Review"
  entityId    String
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Banner {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String
  linkUrl   String?
  position  String   // HOME_HERO, HOME_SIDEBAR, SEARCH_BANNER
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Bảng theo dõi lịch sử và hiệu năng của AI Search
model AiSearchAnalytics {
  id          String   @id @default(uuid())
  queryText   String   // Câu lệnh gốc của user
  parsedQuery Json     // Kết quả JSON sau khi AI phân tích
  isSuccess   Boolean  @default(true)
  executionMs Int      // Thời gian xử lý (ms)
  createdAt   DateTime @default(now())
}

model NearbyLocation {
  id        String   @id @default(uuid())
  hotelId   String
  name      String
  distance  String
  type      String   // "NEARBY" | "TRANSPORT" | "ENTERTAINMENT" | "OTHER"
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}
model LoyaltyTransaction {
  id          String   @id @default(uuid())
  userId      String
  bookingId   String?
  points      Int      // Số điểm cộng (dương) hoặc tiêu/hết hạn (âm)
  type        String   // "EARN" | "SPEND" | "REFUND"
  description String?
  expiredAt   DateTime? // 1 năm sau kể từ ngày EARN
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
